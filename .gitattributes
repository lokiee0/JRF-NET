# Normalize line endings for cross-platform consistency
* text=auto

# Force LF for source files
*.java text eol=lf
*.jsx  text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.xml  text eol=lf

# Force CRLF for Windows scripts
*.bat  text eol=crlf
*.cmd  text eol=crlf
